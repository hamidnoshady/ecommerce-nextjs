# Public base URL used for canonical links and any client-visible site URL needs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WordPress SITE ROOT URL (recommended), e.g. https://cms.example.com
# This app will normalize accidental /wp-json or /wp-json/wp/v2 suffixes.
WP_API_URL=https://your-wordpress-site.test

# WooCommerce Store API base URL (server-side only), must end with /wp-json/wc/store/v1.
WC_STORE_API_URL=https://your-wordpress-site.test/wp-json/wc/store/v1
