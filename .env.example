# Public base URL used for canonical links and any client-visible site URL needs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WordPress GraphQL endpoint used for all CMS content (pages, posts, flexible sections via ACF).
# Example: https://cms.example.com/graphql
WP_GRAPHQL_URL=https://your-wordpress-site.test/graphql

# Optional legacy WordPress base URL (only used to derive /graphql if WP_GRAPHQL_URL is omitted).
WP_API_URL=https://your-wordpress-site.test

# WooCommerce Store API base URL (server-side only), must end with /wp-json/wc/store/v1.
WC_STORE_API_URL=https://your-wordpress-site.test/wp-json/wc/store/v1
